{% macro validation_term(r) -%}{%if '.' in r.switch_field%}{% set value_for = 'self._root_node.by_ref("' + r.switch_field + '")' %}{%else%}{% set value_for = 'self["' + r.switch_field + '"]'%}{%endif%}{{value_for}}{{r.switch_method_call}} {{r.operand}} {{r.switch_value}}{%if r.subject_field %} and not self["{{r.subject_field}}"]{%endif%}{%- endmacro -%}


{% if document_header %}
#
# This code is generated by builder/build_schema.py and builder/README.md
#
from schema import SchemaValidationException
from schema.fields import (
    BooleanField,
    EnumField,
    DynamicEnumField,
    EnumOption,
    RepeatedField,
    SelectFilter,
    SchemaNodeField,
    StringField,
)
from schema.node import SchemaNode, sub_class_search
{% elif document_footer %}

# all classes declared here as a convenience for the override :func:`schema_fusion`
all_schema_node_classes = sub_class_search(SchemaNode)

{% else %}
class {{ class_name }}(SchemaNode):
    {% if ref %}_ref = "{{ ref }}"{% endif %}
    {% if display %}_display = "{{ display }}"{% endif %}
    {% if description %}_description = "{{ description }}"{% endif %}

    {% for field_name, field_instance in schema_fields %}{{ field_name }} = {{ field_instance.__repr__() }}
    {% endfor %}
    {% for field_name, field_instance in descendants %}{{ field_name }} = {{ field_instance.__repr__() }}
    {% endfor %}

    {% if validation_rules %}
    def valid_node(self):
        super().valid_node()
        reasons = []
        {% for r in validation_rules %}
        {% if r.rules is defined %}
        if ({% for sub in r.rules %}({{ validation_term(sub) }}){% if not loop.last %} {{ r.op }} {% endif %}{% endfor %}):
            reasons.append("{{r.rule_message}}")
        {% else %}
        if {{ validation_term(r) }}:
            reasons.append("{{r.subject_field}} is needed for current value in '{{r.switch_field}}'")
        {% endif %}
        {% endfor %}
        if reasons:
            raise SchemaValidationException(reasons)
    {% endif %}

    {% if out_of_scope_rules %}
    @property
    def out_of_scope_fields(self):
        de_scoped = super().out_of_scope_fields
        app_types = set(self._root_node.by_ref("submission-details.application-types"))

        {%for subject_field, app_type_set_repr in out_of_scope_rules %}
        if app_types.isdisjoint({{app_type_set_repr}}):
            de_scoped.add("{{subject_field}}")
        {%endfor%}

        return de_scoped
    {% endif %}

{% endif %}