{% if document_header %}
#
# This code is generated by builder/build_schema.py and builder/README.md
#
from schema import SchemaValidationException
from schema.fields import (
    BooleanField,
    EnumField,
    DynamicEnumField,
    EnumOption,
    RepeatedField,
    SelectFilter,
    SchemaNodeField,
    StringField,
)
from schema.node import SchemaNode, sub_class_search
{% elif document_footer %}

# all classes declared here as a convenience for the override :func:`schema_fusion`
all_schema_node_classes = sub_class_search(SchemaNode)

{% else %}
class {{ class_name }}(SchemaNode):
    {% if ref %}_ref = "{{ ref }}"{% endif %}
    {% if display %}_display = "{{ display }}"{% endif %}
    {% if description %}_description = "{{ description }}"{% endif %}

    {% for field_name, field_instance in schema_fields %}{{ field_name }} = {{ field_instance.__repr__() }}
    {% endfor %}
    {% for field_name, field_instance in descendants %}{{ field_name }} = {{ field_instance.__repr__() }}
    {% endfor %}
    
    {% if validation_rules %}
    def valid_node(self):
        super().valid_node()
        reasons = []
        {% for switch_field, switch_value, required_field in validation_rules %}
        if self["{{switch_field}}"] == {{switch_value}} and not self["{{required_field}}"]:
            reasons.append("{{required_field}} is needed when {{switch_field}} is true")
        {% endfor %}
        if reasons:
            raise SchemaValidationException(reasons)
    {% endif %}

{% endif %}